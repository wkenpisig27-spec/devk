# PKO Website Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# AccountServer Database
DB_ACCOUNT_HOST=localhost\SQLExpress
DB_ACCOUNT_NAME=AccountServer
DB_ACCOUNT_USER=pko_web
DB_ACCOUNT_PASS=YOUR_SECURE_PASSWORD_HERE

# GameDB Database  
DB_GAME_HOST=localhost\SQLExpress
DB_GAME_NAME=GameDB
DB_GAME_USER=pko_web
DB_GAME_PASS=YOUR_SECURE_PASSWORD_HERE

# WebsiteDB Database
DB_WEB_HOST=localhost\SQLExpress
DB_WEB_NAME=WebsiteDB
DB_WEB_USER=pko_web
DB_WEB_PASS=YOUR_SECURE_PASSWORD_HERE

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# JWT Secret Key (generate a secure random string, at least 64 characters)
JWT_SECRET=GENERATE_A_SECURE_64_CHARACTER_RANDOM_STRING_HERE_12345678901234

# JWT Token Expiration (in seconds, 86400 = 24 hours)
JWT_EXPIRATION=86400

# Session Configuration
SESSION_NAME=pko_session
SESSION_LIFETIME=86400

# CSRF Token Secret  
CSRF_SECRET=GENERATE_ANOTHER_SECURE_RANDOM_STRING_HERE_123456789012345

# Password Hashing Cost (higher = more secure but slower, 10-12 recommended)
BCRYPT_COST=10

# =============================================================================
# RATE LIMITING
# =============================================================================

# Login attempts before lockout
MAX_LOGIN_ATTEMPTS=5

# Lockout duration in minutes
LOCKOUT_DURATION=15

# API rate limit (requests per minute)
API_RATE_LIMIT=60

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Server Name (displayed on website)
SERVER_NAME=Pirate King Online

# Server Status Check
GATE_SERVER_IP=127.0.0.1
GATE_SERVER_PORT=1973

# Website URL (for email links, asset URLs)
SITE_URL=http://localhost

# Enable debug mode (set to false in production!)
DEBUG_MODE=false

# =============================================================================
# EMAIL CONFIGURATION (for password reset, verification)
# =============================================================================

MAIL_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=YOUR_SMTP_PASSWORD
SMTP_FROM_NAME=Pirate King Online
SMTP_FROM_EMAIL=noreply@example.com

# =============================================================================
# VOTING CONFIGURATION
# =============================================================================

# Enable voting system
VOTING_ENABLED=true

# Vote cooldown in hours
VOTE_COOLDOWN_HOURS=12

# =============================================================================
# RECAPTCHA (optional, recommended for registration)
# =============================================================================

RECAPTCHA_ENABLED=false
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# =============================================================================
# MAINTENANCE MODE
# =============================================================================

MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=The website is currently under maintenance. Please check back soon!
