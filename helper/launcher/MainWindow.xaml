<Window x:Class="SlimePiratesLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SlimePiratesLauncher"
        mc:Ignorable="d"
        Title="Slime Pirates Online" 
        Height="300" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#141E32"
        Foreground="White"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- Modern Slime Play Button -->
        <Style x:Key="SlimeButtonStyle" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                        <GradientStop Color="#4CDE4C" Offset="0"/>
                        <GradientStop Color="#00A000" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="ScaleTr" ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>
                            
                            <!-- Shadow -->
                            <Border CornerRadius="25" Background="#40000000" Margin="0,4,0,0">
                                <Border.Effect>
                                    <BlurEffect Radius="8"/>
                                </Border.Effect>
                            </Border>

                            <!-- Main Body -->
                            <Border x:Name="border" CornerRadius="25" Background="{TemplateBinding Background}" 
                                    BorderBrush="#80FFFFFF" BorderThickness="1">
                                <Grid>
                                    <!-- Inner Glow (Top) -->
                                    <Border CornerRadius="24" Margin="1">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,0.5">
                                                <GradientStop Color="#60FFFFFF" Offset="0"/>
                                                <GradientStop Color="Transparent" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <ContentPresenter.Effect>
                                            <DropShadowEffect ShadowDepth="1" BlurRadius="2" Opacity="0.5"/>
                                        </ContentPresenter.Effect>
                                    </ContentPresenter>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                            <GradientStop Color="#66FF66" Offset="0"/>
                                            <GradientStop Color="#00C800" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <!-- Pop Animation Check -->
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ScaleTr" Storyboard.TargetProperty="ScaleX" To="1.05" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="ScaleTr" Storyboard.TargetProperty="ScaleY" To="1.05" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ScaleTr" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="ScaleTr" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#008000"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="2"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <BlurEffect Radius="2"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sleek Glass Button Style -->
        <Style x:Key="GlassButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#99101015"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="8" Background="{TemplateBinding Background}" 
                                BorderBrush="#40FFFFFF" BorderThickness="1.5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CC202030"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FFFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Progress Bar Style (Modern) -->
        <Style TargetType="ProgressBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Name="PART_Track" CornerRadius="6" Background="#80000000" BorderBrush="#20FFFFFF" BorderThickness="1"/>
                            <Border Name="PART_Indicator" CornerRadius="6" HorizontalAlignment="Left">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                        <GradientStop Color="#FFA500" Offset="0"/>
                                        <GradientStop Color="#FFD700" Offset="1"/>
                                        <!-- Shimmer effect -->
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#FFD700" BlurRadius="10" ShadowDepth="0" Opacity="0.4"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Background Layer -->
        <!-- Fallback Gradient -->
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#141E32" Offset="0"/>
                    <GradientStop Color="#05050A" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        
        <!-- Image Background -->
        <Image x:Name="bgImage" Source="updater/assets/bg_img.png" 
               Stretch="UniformToFill" 
               RenderOptions.BitmapScalingMode="HighQuality"/>
        
        <!-- Dark Gradient Overlay -->
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#80000000" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        
        <!-- Main UI Grid -->
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/> <!-- Top Spacer -->
                <RowDefinition Height="Auto"/> <!-- Status -->
                <RowDefinition Height="Auto"/> <!-- Progress -->
                <RowDefinition Height="Auto"/> <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Status Text -->
            <TextBlock x:Name="txtStatus" Grid.Row="1" Text="Initializing..." 
                       Foreground="White" FontWeight="SemiBold" FontSize="14" 
                       Margin="0,0,0,5" VerticalAlignment="Bottom">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="3" ShadowDepth="1"/>
                </TextBlock.Effect>
            </TextBlock>
            
            <!-- Progress Bar -->
            <ProgressBar x:Name="progressBar" Grid.Row="2" Height="15" Value="0" Maximum="100" Margin="0,0,0,20">
                <ProgressBar.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="2" Opacity="0.5"/>
                </ProgressBar.Effect>
            </ProgressBar>
            
            <!-- Buttons -->
            <Grid Grid.Row="3" Height="50">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                    <Button x:Name="btnCheck" Content="CHECK FILES" Width="120" Height="40" Margin="0,0,10,0" Style="{StaticResource GlassButtonStyle}" Click="BtnCheck_Click"/>
                    <Button Content="WEBSITE" Width="100" Height="40" Margin="0,0,10,0" Style="{StaticResource GlassButtonStyle}" Click="BtnWebsite_Click"/>
                    <Button x:Name="btnPlay" Content="PLAY" Width="140" Height="50" Style="{StaticResource SlimeButtonStyle}" Click="BtnPlay_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
