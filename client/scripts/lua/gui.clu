-----------------------------------------------------------------------
-- Initialization
-----------------------------------------------------------------------

-- Set drag snap grid
UI_SetDragSnapToGrid(4, 4)

-- Form templates (corresponds to UITemplete.h)
FORM_LOGIN = 0
FORM_MAIN = 1
FORM_SELECT_CHA = 2
FORM_EDITOR = 3
FORM_SWITCH_SCENE = 4
FORM_CREATE_CHA = 5
FORM_SELECT = 6
UI_SetFormTempleteMax(7)

FORM_DIALOG = FORM_SWITCH_SCENE

-----------------------------------------------------------------------
-- Load form scripts
-----------------------------------------------------------------------

UI_LoadScript("scripts/lua/forms/main.clu")
UI_LoadScript("scripts/lua/forms/login.clu")
