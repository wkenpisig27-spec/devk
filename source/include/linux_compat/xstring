// xstring - Linux compatibility shim for MSVC <xstring>
// MSVC's <xstring> is an internal header that provides std::basic_string.
// On Linux/GCC, just include <string> which provides the same.
#ifndef _XSTRING_LINUX_COMPAT
#define _XSTRING_LINUX_COMPAT

#if defined(_WIN32)
#error "This shim should not be used on Windows - use the real xstring"
#endif

#include <string>

#endif // _XSTRING_LINUX_COMPAT
