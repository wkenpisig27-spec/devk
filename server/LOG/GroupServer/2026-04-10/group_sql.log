				FOR INSERT
				AS
				BEGIN
					declare @l_icon smallint
					select @l_icon =convert(smallint,SUBSTRING(inserted.look,5,1)) from inserted
					update character set icon =@l_icon where cha_id in (select cha_id from inserted)
				END
		]
